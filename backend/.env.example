DATABASE_URL=postgresql://user:password@host:5432/food_rescue_nepal?sslmode=require
JWT_ACCESS_SECRET=min_32_char_random_string_here_change_me
JWT_REFRESH_SECRET=different_min_32_char_string_here_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
PORT=3000
NODE_ENV=production
# Production: set to your domain(s), e.g. https://app.foodrescuenepal.com
# Development: * (allows all origins)
CORS_ORIGIN=https://app.foodrescuenepal.com
ADMIN_SEED_EMAIL=admin@foodrescuenepal.com
# Generate a strong random password: openssl rand -base64 24
ADMIN_SEED_PASSWORD=CHANGE_ME_BEFORE_SEEDING
